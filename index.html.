var LS={
  get:function(k,fb){try{var v=localStorage.getItem(k);return v!=null?JSON.parse(v):fb;}catch(e){return fb;}},
  set:function(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch(e){}}
