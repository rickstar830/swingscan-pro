‘<div style="font-size:10.5px;font-weight:800;color:'+(met>=4?'var(--bull)':met>=3?'var(--warn)':'var(--bear)')+'">’+met+’/5 met</div>’+
‘</div>’+
‘<div style="display:flex;flex-direction:column;gap:4px">’+
conds.map(function(c){return’<div style="display:flex;align-items:center;gap:6px;font-size:10px;color:'+(c[1]?'var(--bull)':'var(--sub)')+'">’+
‘<span style="width:14px;height:14px;border-radius:3px;background:'+(c[1]?'rgba(0,214,143,.18)':'rgba(61,85,117,.15)')+';display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0">’+(c[1]?’✓’:’—’)+’</span>’+c[0]+’</div>’;}).join(’’)+
‘</div></div>’+
‘<div style="padding:11px 13px;border-bottom:1px solid var(--border)"><div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px">’+
stats.map(function(r){return’<div style="background:var(--bg2);border-radius:8px;padding:8px;border:1px solid var(--border)"><div style="font-size:7.5px;color:var(--mute);text-transform:uppercase;margin-bottom:2px;letter-spacing:.06em">’+r[0]+’</div><div class="mono" style="font-size:11px;font-weight:600;color:'+r[2]+'">’+r[1]+’</div></div>’;}).join(’’)+
‘</div></div>’+
((s.signals&&s.signals.length)?’<div style="padding:11px 13px;border-bottom:1px solid var(--border)"><div style="font-size:8.5px;color:var(--sub);font-weight:700;text-transform:uppercase;margin-bottom:6px;letter-spacing:.07em">Signals</div><div style="display:flex;gap:5px;flex-wrap:wrap">’+s.signals.map(function(sg){return’<span class="pill" style="background:'+sg.color+'14;color:'+sg.color+';border:1px solid '+sg.color+'25">’+sg.icon+’ ‘+sg.label+’</span>’;}).join(’’)+’</div></div>’:’’)+
// Position sizer
‘<div style="padding:11px 13px"><div style="font-size:8.5px;color:var(--sub);font-weight:700;text-transform:uppercase;margin-bottom:8px;letter-spacing:.07em">Position Sizing</div>’+
‘<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:8px">’+
‘<div><div style="font-size:7.5px;color:var(--mute);text-transform:uppercase;margin-bottom:2px">Account $</div><input type="number" id="psa" value="10000" oninput="cp(\''+sym+'\')" style="width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:7px;padding:6px;color:var(--bright);font-size:11px;font-family:monospace"></div>’+
‘<div><div style="font-size:7.5px;color:var(--mute);text-transform:uppercase;margin-bottom:2px">Risk %</div><input type="number" id="psr" value="1" oninput="cp(\''+sym+'\')" style="width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:7px;padding:6px;color:var(--bright);font-size:11px;font-family:monospace"></div>’+
‘<div><div style="font-size:7.5px;color:var(--mute);text-transform:uppercase;margin-bottom:2px">Stop %</div><input type="number" id="pss" value="8" oninput="cp(\''+sym+'\')" style="width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:7px;padding:6px;color:var(--bright);font-size:11px;font-family:monospace"></div>’+
‘</div><div id="pso" style="background:var(--bg2);border-radius:9px;padding:10px;border:1px solid var(--border);font-size:11px;color:var(--sub)">Enter values above…</div></div>’+
‘</div>’;
setTimeout(function(){cp(sym);},50);
}

function cp(sym){
var s=S.cache[sym]||S.results.find(function(r){return r.sym===sym;});if(!s)return;
var acc=parseFloat((document.getElementById(‘psa’)&&document.getElementById(‘psa’).value)||10000)||10000;
var risk=parseFloat((document.getElementById(‘psr’)&&document.getElementById(‘psr’).value)||1)||1;
var stop=parseFloat((document.getElementById(‘pss’)&&document.getElementById(‘pss’).value)||8)||8;
var p=s.price||1,rAmt=acc*(risk/100),sDist=p*(stop/100);
var shares=sDist>0?Math.floor(rAmt/sDist):0,posSize=shares*p;
var el=document.getElementById(‘pso’);if(!el)return;
el.innerHTML=’<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:6px">’+
[[‘Shares’,shares>0?shares.toLocaleString():’—’,‘var(–bright)’],[‘Position’,shares>0?’$’+posSize.toFixed(0):’—’,‘var(–acc)’],[‘Stop Price’,’$’+(p-sDist).toFixed(2),‘var(–bear)’],[‘Portfolio %’,shares>0?(posSize/acc*100).toFixed(1)+’%’:’—’,‘var(–sub)’]].map(function(r){
return’<div><div style="font-size:7.5px;color:var(--mute);text-transform:uppercase;margin-bottom:1px">’+r[0]+’</div><div class="mono" style="font-size:13px;color:'+r[2]+';font-weight:700">’+r[1]+’</div></div>’;
}).join(’’)+
‘</div><div style="font-size:9px;color:var(--sub);border-top:1px solid var(--border);padding-top:6px">Risk $’+rAmt.toFixed(0)+’ at ‘+risk+’% · Stop ‘+stop+’% below entry</div>’;
}
function closeDet(){S.detSym=null;render();}

function saveKey(){var k=(document.getElementById(‘ki’)&&document.getElementById(‘ki’).value||’’).trim();if(!k){toast(‘Enter key first’,‘warn’);return;}S.apiKey=k;LS.set(‘fh_key’,k);toast(‘API key saved’,‘ok’);render();}
function testKey(){
var k=(document.getElementById(‘ki’)&&document.getElementById(‘ki’).value||’’).trim();if(!k){toast(‘Enter key first’,‘warn’);return;}
var tres=document.getElementById(‘tres’);if(tres){tres.style.display=‘block’;tres.style.color=‘var(–sub)’;tres.textContent=‘Testing…’;}
var prev=S.apiKey;S.apiKey=k;
fhFetch(’/quote’,{symbol:‘AAPL’},null).then(function(r){
S.apiKey=prev;
if(r===’**BAD_KEY**’){if(tres){tres.style.color=‘var(–bear)’;tres.textContent=‘Invalid key’;}}
else if(r&&r.c>0){if(tres){tres.style.color=‘var(–bull)’;tres.textContent=‘Connected! AAPL = $’+Number(r.c).toFixed(2);}S.apiKey=k;LS.set(‘fh_key’,k);}
else{if(tres){tres.style.color=‘var(–warn)’;tres.textContent=‘No data (market closed?) — key saved.’;}S.apiKey=k;LS.set(‘fh_key’,k);}
});
}
function loadOne(sym){fhFetch(’/quote’,{symbol:sym},null).then(function(q){if(q&&q.c>0){var sig=buildSig(q);S.cache[sym]=mkStock(sym,q,sig);render();}});}
function addW(){var sym=prompt(‘Ticker (e.g. NVDA):’);if(!sym)return;sym=sym.trim().toUpperCase();if(S.watchlist.indexOf(sym)===-1){S.watchlist.push(sym);LS.set(‘fh_wl’,S.watchlist);}render();}
function rmW(sym){S.watchlist=S.watchlist.filter(function(s){return s!==sym;});LS.set(‘fh_wl’,S.watchlist);render();}
function togW(sym){if(S.watchlist.indexOf(sym)>-1)rmW(sym);else{S.watchlist.push(sym);LS.set(‘fh_wl’,S.watchlist);}openDet(sym);}
function clearQC(){var ks=[];for(var i=0;i<localStorage.length;i++){var k=localStorage.key(i);if(k&&k.indexOf(‘fhq_’)===0)ks.push(k);}ks.forEach(function(k){localStorage.removeItem(k);});toast(‘Cleared ‘+ks.length+’ quotes’,‘ok’);}
function clearAll(){if(confirm(‘Reset all data?’)){localStorage.clear();location.reload();}}
function exportCSV(){
var rows=[[‘Symbol’,‘Score’,‘Grade’,‘Scorecard’,‘Price’,‘Change%’,‘Volume’,‘Signals’].join(’,’)];
S.results.forEach(function(s){rows.push([s.sym,Math.round(s.score),grade(s.score),scorecard(s).label,Number(s.price).toFixed(2),Number(s.changePct).toFixed(2),s.volume,(s.signals||[]).map(function(x){return x.label;}).join(’; ‘)].join(’,’));});
var a=document.createElement(‘a’);a.href=URL.createObjectURL(new Blob([rows.join(’\n’)],{type:‘text/csv’}));a.download=‘swingscan_’+new Date().toISOString().split(‘T’)[0]+’.csv’;a.click();
}

function showDisc(){
var m=document.createElement(‘div’);m.className=‘modal’;m.id=‘dm’;
m.innerHTML=’<div class="mbox"><div style="text-align:center;margin-bottom:19px">’+
‘<div style="width:48px;height:48px;border-radius:13px;background:linear-gradient(135deg,#4F7CFF,#8B5CF6);display:flex;align-items:center;justify-content:center;font-size:21px;margin:0 auto 11px;box-shadow:0 8px 28px rgba(79,124,255,.4)">◈</div>’+
‘<div class="syne" style="font-size:23px;font-weight:900;color:var(--bright)">SwingScan<span style="color:var(--acc)"> Pro</span></div>’+
‘<div style="font-size:8.5px;color:var(--sub);letter-spacing:.15em;margin-top:4px">INSTITUTIONAL SWING SCANNER · MEGA 3000+</div></div>’+
‘<div style="background:var(--bg2);border:1px solid var(--bordHi);border-radius:11px;padding:12px;margin-bottom:15px"><div style="font-size:9.5px;color:var(--warn);font-weight:700;margin-bottom:5px">⚠ RISK DISCLOSURE</div>’+
‘<div style="font-size:10.5px;color:var(--sub);line-height:1.7">For <b style="color:var(--text)">research only</b>. Not financial advice. <b style="color:var(--text)">Trading involves substantial risk of loss.</b></div></div>’+
‘<label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;margin-bottom:15px;padding:11px;background:var(--bg2);border:1px solid var(--border);border-radius:10px">’+
‘<input type="checkbox" id="dc" style="width:16px;height:16px;margin-top:1px;accent-color:var(--acc);flex-shrink:0" onchange="var b=document.getElementById(\'db\');b.disabled=!this.checked;b.style.opacity=this.checked?1:.35">’+
‘<span style="font-size:11px;color:var(--text);line-height:1.6">I understand this is for research only. I am responsible for my own trading decisions.</span></label>’+
‘<button id="db" disabled onclick="accD()" style="width:100%;padding:14px;border-radius:12px;background:linear-gradient(135deg,var(--acc),var(--alt));color:#fff;font-weight:700;font-size:13.5px;opacity:.35">Enter SwingScan Pro →</button></div>’;
document.body.appendChild(m);
}
function accD(){LS.set(‘fh_disc’,true);S.discOk=true;var m=document.getElementById(‘dm’);if(m)m.remove();init();}
function init(){go(‘dash’);if(S.apiKey&&S.results.length===0&&!S.scanning){setTimeout(function(){runScan(‘quick’);},1000);}}

if(!S.discOk)showDisc();else init();
</script>

