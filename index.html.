<script>
'use strict';
window.onerror=function(m,s,l){
  var el=document.getElementById('pg');
  if(el)el.innerHTML='<div style="padding:20px;color:#FF3B5C;font-family:monospace;font-size:11px;word-break:break-all"><b>JS Error line '+l+':</b><br>'+m+'</div>';
