var S={
  apiKey:LS.get('fh_key',''),tab:'dash',results:[],cache:{},
  scanning:false,prog:0,msg:'',checked:0,total:0,phase:'',
  errs:0,goodFetches:0,lastErr:'',lastTransport:'',
  universe:LS.get('fh_uni','u100'),
  watchlist:LS.get('fh_wl',['NVDA','TSLA','AAPL','AMD','META']),
  discOk:LS.get('fh_disc',false),detSym:null
};
var CANCEL=false;
var sleep=function(ms){return new Promise(function(r){setTimeout(r,ms);});};

function getSyms(){return(UNIS[S.universe]||UNIS.u100).syms;}
function isMega(){return !!(UNIS[S.universe]&&UNIS[S.universe].quoteOnly);}

var fp=function(v){return v==null?’—’:’$’+Number(v).toFixed(2);};
var fpc=function(v){if(v==null)return’—’;var n=Number(v);return(n>=0?’+’:’’)+n.toFixed(2)+’%’;};
var fv=function(v){v=Number(v)||0;return v>=1e9?(v/1e9).toFixed(1)+‘B’:v>=1e6?(v/1e6).toFixed(1)+‘M’:v>=1e3?(v/1e3).toFixed(0)+‘K’:’—’;};
var col=function(s){return s>=70?’#00D68F’:s>=45?’#FFB800’:’#FF3B5C’;};
var grd=function(s){return s>=90?‘A+’:s>=80?‘A’:s>=70?‘B+’:s>=60?‘B’:s>=50?‘C’:s>=40?‘D’:‘F’;};

function scorecard(s){
var sc=s.score||0,chg=s.changePct||0;
if(sc>=80)  return{label:‘Strong Buy’,short:‘STRONG BUY’,c:’#00D68F’,bg:‘rgba(0,214,143,.18)’};
if(sc>=65)  return{label:‘Buy’,       short:‘BUY’,       c:’#00D68F’,bg:‘rgba(0,214,143,.13)’};
if(sc>=45)  return{label:‘Hold’,      short:‘HOLD’,      c:’#FFB800’,bg:‘rgba(255,184,0,.15)’};
if(sc>=30)  return{label:‘Watch’,     short:‘WATCH’,     c:’#FF8C00’,bg:‘rgba(255,140,0,.13)’};
if(chg<=-3) return{label:‘Sell’,      short:‘SELL’,      c:’#FF3B5C’,bg:‘rgba(255,59,92,.18)’};
if(sc>=20)  return{label:‘No Trade’,  short:‘NO TRADE’,  c:’#3D5575’,bg:‘rgba(61,85,117,.18)’};
return           {label:‘Avoid’,      short:‘AVOID’,     c:’#FF3B5C’,bg:‘rgba(255,59,92,.10)’};
}
function sigPills(s){
var p=[],chg=s.changePct||0,vr=(s.avgVol>0?s.volume/s.avgVol:0);
if(s.rsi!=null&&s.macdHist!=null&&chg>0)p.push({t:‘ALL ALIGNED’,c:’#00D68F’});
if(s.rsi!=null&&s.rsi>35&&s.rsi<55)     p.push({t:‘IN ZONE’,c:’#4F7CFF’});
if(s.bbBW!=null&&s.bbBW<0.06)           p.push({t:‘SQUEEZE’,c:’#FFB800’});
if(vr>2)                                 p.push({t:‘SMART MONEY’,c:’#8B5CF6’});
if(chg>3&&vr>1.5)                        p.push({t:‘MOMENTUM’,c:’#00D68F’});
if(chg<-3&&vr>1.5)                       p.push({t:‘BREAKDOWN’,c:’#FF3B5C’});
if(s.score>=75&&chg>0)                   p.push({t:‘OPTIMAL NOW’,c:’#00D68F’});
return p.slice(0,3);
}
var toastT;
function toast(msg,type,ms){
type=type||‘ok’;ms=ms||3500;
var el=document.getElementById(‘toast’);if(!el)return;
var c=type===‘err’?’#FF3B5C’:type===‘warn’?’#FFB800’:’#00D68F’;
el.style.cssText=‘display:flex;border:1px solid ‘+c+‘45’;
el.innerHTML=’<span style="color:'+c+';font-weight:700;font-size:13px">’+(type===‘err’?’✕’:’✓’)+’</span><span style="flex:1">’+msg+’</span>’;
clearTimeout(toastT);toastT=setTimeout(function(){el.style.display=‘none’;},ms);
}
function scoreCircle(s,sz){
sz=sz||46;var r=sz/2-3.5,circ=2*Math.PI*r,pct=s/100,c=col(s),g=grd(s);
var d1=Math.round(circ*pct),d2=Math.round(circ*(1-pct)),half=sz/2;
return’<div style="position:relative;width:'+sz+'px;height:'+sz+'px;flex-shrink:0">’+
‘<svg width="'+sz+'" height="'+sz+'" style="transform:rotate(-90deg)">’+
‘<circle cx="'+half+'" cy="'+half+'" r="'+r+'" fill="none" stroke="'+c+'22" stroke-width="3.5"/>’+
‘<circle cx="'+half+'" cy="'+half+'" r="'+r+'" fill="none" stroke="'+c+'" stroke-width="3.5" stroke-dasharray="'+d1+' '+d2+'" stroke-linecap="round"/></svg>’+
‘<div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center">’+
‘<div style="font-family:monospace;font-size:'+Math.round(sz*.21)+'px;font-weight:700;color:'+c+';line-height:1">’+Math.round(s)+’</div>’+
‘<div style="font-size:'+Math.round(sz*.15)+'px;font-weight:800;color:'+c+'">’+g+’</div>’+
‘</div></div>’;
}
function sparkSVG(data,pos,h){
h=h||36;if(!data||data.length<2)return’<div style="height:'+h+'px"></div>’;
var c=pos?’#00D68F’:’#FF3B5C’,W=180,pad=2,ah=h-pad*2;
var pts=data.map(function(v,i){return(pad+i*(W-2*pad)/(data.length-1)).toFixed(1)+’,’+(pad+ah*(1-v)).toFixed(1);}).join(’ ‘);
var gid=‘sp’+Math.floor(Math.random()*99999);
return’<svg width="100%" height="'+h+'" viewBox="0 0 '+W+' '+h+'" preserveAspectRatio="none">’+
‘<defs><linearGradient id="'+gid+'" x1="0" y1="0" x2="0" y2="1">’+
‘<stop offset="0%" stop-color="'+c+'" stop-opacity=".18"/>’+
‘<stop offset="100%" stop-color="'+c+'" stop-opacity="0"/></linearGradient></defs>’+
‘<polygon points="'+pts+' '+(W-pad)+','+(h-pad)+' '+pad+','+(h-pad)+'" fill="url(#'+gid+')"/>’+
‘<polyline points="'+pts+'" fill="none" stroke="'+c+'" stroke-width="1.8" stroke-linejoin="round"/></svg>’;
}
function tickerBar(){
var syms=[‘NVDA’,‘TSLA’,‘AAPL’,‘AMZN’,‘MSFT’,‘META’,‘AMD’,‘QQQ’];
var items=syms.map(function(sym){
var s=S.cache[sym];if(!s||!s.price)return’’;
var pos=(s.changePct||0)>=0,c=pos?‘var(–bull)’:‘var(–bear)’,sc=scorecard(s);
return’<span style="display:inline-flex;align-items:center;gap:5px;padding:0 14px;white-space:nowrap;font-weight:600">’+
‘<b style="color:var(--bright)">’+sym+’</b>’+
‘<span style="font-family:monospace;color:'+c+'">’+fpc(s.changePct)+’</span>’+
‘<span style="font-size:7.5px;padding:1px 5px;border-radius:3px;background:'+sc.bg+';color:'+sc.c+';font-weight:700">’+sc.short+’</span>’+
‘</span>’;
}).filter(Boolean);
if(items.length<2)return’’;
var inner=items.join(’’)+items.join(’’);
return’<div style="overflow:hidden;background:var(--bg1);border-bottom:1px solid var(--border);padding:6px 0;font-size:10px">’+
‘<div style="display:inline-flex;animation:tick 32s linear infinite">’+inner+’</div></div>’;
}

// ═══════════════════════════════════════════════════════════
// TRANSPORT FIX: Multi-proxy network layer
// Tries 10 combinations: direct fetch/XHR + 4 CORS proxies × 2 transports
// At least one works in any environment (browser, Claude sandbox, file://)
// ═══════════════════════════════════════════════════════════
// TRANSPORT FIX: 4 CORS proxies — different ones work in different sandboxes
var PROXIES = [
‘https://corsproxy.io/?url=’,
‘https://api.allorigins.win/raw?url=’,
‘https://thingproxy.freeboard.io/fetch/’,
‘https://api.codetabs.com/v1/proxy?quest=’
];
var FH = ‘https://finnhub.io/api/v1’;

// TRANSPORT FIX: tryFetch — fetch() with 10s timeout, never throws
function tryFetch(url){
return new Promise(function(resolve){
var done=false;
var tid=setTimeout(function(){
if(!done){done=true;resolve({err:‘timeout’});}
},10000);
try{
fetch(url).then(function(r){
if(done)return;done=true;clearTimeout(tid);
r.text().then(function(t){resolve({status:r.status,body:t});})
.catch(function(){resolve({err:‘parse’});});
}).catch(function(e){
if(done)return;done=true;clearTimeout(tid);
resolve({err:e.message||‘fetch-err’});
});
}catch(e){done=true;clearTimeout(tid);resolve({err:e.message||‘fetch-throw’});}
});
}

// TRANSPORT FIX: tryXhr — XHR with 10s timeout, never throws
function tryXhr(url){
return new Promise(function(resolve){
try{
var x=new XMLHttpRequest();
x.open(‘GET’,url,true);x.timeout=10000;
x.onload=function(){resolve({status:x.status,body:x.responseText});};
x.onerror=function(){resolve({err:‘xhr-net’});};
x.ontimeout=function(){resolve({err:‘xhr-timeout’});};
x.send();
}catch(e){resolve({err:e.message||‘xhr-throw’});}
});
}

// TRANSPORT FIX: apiGet — tries all transports, returns first success
// Order: direct fetch → direct XHR → 4 proxies (fetch+XHR each)
async function apiGet(url){
var attempts=[
{label:‘fetch’,    fn:tryFetch, arg:url},
{label:‘xhr’,      fn:tryXhr,   arg:url}
];
// Add all 4 proxies as fetch+xhr pairs
for(var pi=0;pi<PROXIES.length;pi++){
var px=PROXIES[pi]+encodeURIComponent(url);
attempts.push({label:‘proxy’+(pi+1)+’-fetch’,fn:tryFetch,arg:px});
attempts.push({label:‘proxy’+(pi+1)+’-xhr’,  fn:tryXhr,  arg:px});
}

for(var ai=0;ai<attempts.length;ai++){
var a=attempts[ai];
var r=await a.fn(a.arg);
if(r.status){
S.lastTransport=a.label;
return r;
}
S.lastErr=a.label+’:’+r.err;
}
S.lastTransport=‘none’;
S.lastErr=‘All ‘+attempts.length+’ transports failed’;
return{err:S.lastErr};
}

// TRANSPORT FIX: parseQ — safe JSON parse of API response
function parseQ(r){
if(!r||r.err)return null;
if(r.status===401||r.status===403)return’**BAD_KEY**’;
if(r.status===429)return’**RATE_LIMIT**’;
if(r.status!==200)return null;
try{
// allorigins.win wraps response: {“status”:{“url”:…},“contents”:”…”}
var j=JSON.parse(r.body);
if(j&&j.contents&&typeof j.contents===‘string’){
try{j=JSON.parse(j.contents);}catch(e){}
}
return j;
}catch(e){return null;}
}

// Rate limiter — 25rpm, first call instant
function makeLim(rpm){
rpm=rpm||25;
var nextAt=0,gap=Math.ceil(60000/rpm)+200;
return{
wait:function(){
return new Promise(function(res){
var now=Date.now();
var wait=nextAt===0?0:Math.max(0,nextAt-now);
nextAt=Math.max(now,nextAt>0?nextAt:now)+gap;
setTimeout(res,wait);
});
},
reset:function(){nextAt=Date.now()+gap;}
};
}

// Fetch single quote — AFTER-HOURS FIX: accepts c=0 if pc>0
async function fetchQ(sym,lim){
if(!S.apiKey||CANCEL)return null;
if(lim)await lim.wait();
if(CANCEL)return null;
var url=FH+’/quote?symbol=’+encodeURIComponent(sym)+’&token=’+encodeURIComponent(S.apiKey.trim());
var r=await apiGet(url);
var d=parseQ(r);
if(d===’**BAD_KEY**’)return’**BAD_KEY**’;
if(d===’**RATE_LIMIT**’){
S.errs++;S.lastErr=‘429’;
if(lim)lim.reset();
S.msg=’⚠ Rate limited — pausing 60s…’;render();
await sleep(60000);
if(CANCEL)return null;
if(lim)await lim.wait();
return parseQ(await apiGet(url));
}
if(!d){S.errs++;return null;}
return d;
}

async function fhFetch(path,params,lim){
if(!S.apiKey||CANCEL)return null;
if(lim)await lim.wait();
if(CANCEL)return null;
var p=Object.assign({},params,{token:S.apiKey.trim()});
var qs=Object.keys(p).map(function(k){return encodeURIComponent(k)+’=’+encodeURIComponent(p[k]);}).join(’&’);
var r=await apiGet(FH+path+’?’+qs);
var d=parseQ(r);
if(d===’**RATE_LIMIT**’){S.errs++;if(lim)lim.reset();await sleep(60000);return null;}
return(d===’**BAD_KEY**’)?’**BAD_KEY**’:d;
}

// Quote data helper — AFTER-HOURS FIX: use pc when c=0
function normaliseQ(q){
if(!q)return null;
var c=Number(q.c)||0,pc=Number(q.pc)||0;
var price=c>0?c:pc;
if(price<=0)return null;
return{c:price,o:Number(q.o)||price,h:Number(q.h)||price,l:Number(q.l)||price,
pc:pc||price,v:Number(q.v)||0,av:Number(q.av)||0,dp:Number(q.dp)||0};
}

function buildSig(q){
var sigs=[],score=35;
try{
var price=Number(q.c)||0,prev=Number(q.pc)||price,open=Number(q.o)||price;
var high=Number(q.h)||price,low=Number(q.l)||price;
var vRaw=Number(q.v)||0,avgV=Number(q.av)||0;
var vol=vRaw>0?vRaw:(avgV>0?avgV*0.5:0);
var chg=prev>0?(price-prev)/prev*100:(Number(q.dp)||0);
var frOp=open>0?(price-open)/open*100:0;
var vR=avgV>0?vol/avgV:(vol>0?1:0);
var rng=(high>low&&low>0)?(high-low)/low*100:0;
function add(k,lb,ic,co,pts){sigs.push({key:k,label:lb,icon:ic,color:co});score+=pts;}
if(chg>5&&vR>1.2)      add(‘surge’,‘Surge Day’,   ‘🚀’,’#00D68F’,18);
else if(chg>3&&vR>0.8) add(‘strong’,‘Strong Day’, ‘⇧’,  ‘#00D68F’,14);
else if(chg>1.5)       add(‘mom’,  ‘Positive’,    ‘↑’,  ‘#00D68F’, 9);
else if(chg>0.5)       add(‘mild’, ‘Mild Gain’,   ‘·’,   ‘#3D5575’, 6);
else if(chg>0)         add(‘flat’, ‘Stable’,      ‘—’,  ‘#3D5575’, 4);
if(chg<-4&&vR>1.5)     add(‘sh_d’,‘Short:Break’,  ‘↓↓’,’#FF3B5C’,14);
else if(chg<-2.5&&vR>1)add(‘sh_m’,‘Short:Fall’,   ‘↓’,       ‘#FF3B5C’,10);
else if(chg<-1.5)      add(‘sh_w’,‘Short:Weak’,   ‘↘’,       ‘#FF3B5C’, 7);
if(frOp>1.5&&chg>0)      add(‘intra’,‘Above Open’,’▲’,’#00D68F’, 9);
else if(frOp>0.3&&chg>=0)add(‘hold’,‘Holding’,    ‘—’,’#3D5575’, 5);
if(rng>4&&vR>1.2)      add(‘rng2’,‘High Range’,’◉’,’#4F7CFF’,12);
else if(rng>2.5)       add(‘rng’, ‘Range Exp’, ‘◈’,’#4F7CFF’, 8);
else if(rng>1.5)       add(‘rng1’,‘Active’,    ‘◬’,’#3D5575’, 4);
if(vR>=3)       add(‘v3’,‘Vol 3x’,’◉’,’#4F7CFF’,17);
else if(vR>=2)  add(‘v2’,‘Vol 2x’,’◉’,’#4F7CFF’,13);
else if(vR>=1.4)add(‘v1’,‘Vol+’,  ‘◬’,’#4F7CFF’, 8);
else if(vR>=1)  add(‘vm’,‘Vol’,   ‘◬’,’#3D5575’, 5);
else if(vol>0)  add(‘vl’,‘LowVol’,’·’, ‘#1A2840’, 2);
if(chg<-2.5&&frOp>1.5)add(‘bnc’,‘Bounce’,’↻’,’#FFB800’,11);
if(chg>0.5&&vR>=1&&rng>1)score+=5;if(chg>1.5&&frOp>0.3)score+=4;
if(chg>3&&vol>0)score+=3;if(chg<-3&&vR>1.5&&rng>3)score+=6;
score=Math.min(100,Math.max(0,score));
return{score:score,sigs:sigs,price:price,changePct:chg,change:price-prev,
open:open,high:high,low:low,prevClose:prev,volume:vol,avgVol:avgV};
}catch(e){return{score:35,sigs:[],price:Number(q.c)||0,changePct:0,change:0,open:0,high:0,low:0,prevClose:0,volume:0,avgVol:0};}
}
function mkStock(sym,q,sig){
return{sym:String(sym),name:String(sym),sector:’’,price:sig.price,
changePct:Number(sig.changePct.toFixed(3)),change:sig.change,
open:sig.open,high:sig.high,low:sig.low,prevClose:sig.prevClose,
volume:sig.volume,avgVol:sig.avgVol,score:sig.score,signals:sig.sigs,
