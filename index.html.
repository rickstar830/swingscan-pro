function calcInd(cl){
var sma=function(a,p){if(a.length<p)return null;return a.slice(-p).reduce(function(x,y){return x+y;},0)/p;};
var ema=function(a,p){if(a.length<p)return null;var k=2/(p+1),e=a.slice(0,p).reduce(function(x,y){return x+y;},0)/p;for(var i=p;i<a.length;i++)e=a[i]*k+e*(1-k);return e;};
var rsi=function(a,p){p=p||14;if(a.length<p+1)return null;var g=0,l=0;for(var i=1;i<=p;i++){var d=a[i]-a[i-1];d>0?g+=d:l-=d;}var ag=g/p,al=l/p;for(var i=p+1;i<a.length;i++){var d=a[i]-a[i-1];ag=(ag*(p-1)+(d>0?d:0))/p;al=(al*(p-1)+(d<0?-d:0))/p;}return 100-(100/(1+(al===0?1e9:ag/al)));};
var macd=function(a){if(a.length<26)return{h:null,ph:null};var e12=a.map(function(*,i){return ema(a.slice(0,i+1),12);});var e26=a.map(function(*,i){return ema(a.slice(0,i+1),26);});var ln=e12.map(function(v,i){return(v!=null&&e26[i]!=null)?v-e26[i]:null;}).filter(function(v){return v!=null;});if(ln.length<9)return{h:null,ph:null};var sg=ln.map(function(_,i){return ema(ln.slice(0,i+1),9);});return{h:ln[ln.length-1]-sg[sg.length-1],ph:ln.length>1?ln[ln.length-2]-sg[sg.length-2]:null};};
var bb=function(a,p){p=p||20;if(a.length<p)return{u:null,l:null,bw:null};var sl=a.slice(-p),m=sl.reduce(function(x,y){return x+y;},0)/p,sd=Math.sqrt(sl.reduce(function(x,y){return x+(y-m)*(y-m);},0)/p);return{u:m+2*sd,l:m-2*sd,bw:m>0?(4*sd)/m:null};};
var mv=macd(cl),bv=bb(cl);
return{rsi:rsi(cl),sma20:sma(cl,20),sma50:sma(cl,50),sma200:sma(cl,200),ema9:ema(cl,9),bbUpper:bv.u,bbLower:bv.l,bbBW:bv.bw,macdHist:mv.h,prevMacdHist:mv.ph};
}
